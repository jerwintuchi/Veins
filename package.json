{
  "name": "testament",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev:server": "pnpm --filter @testament/server dev",
    "test": "pnpm -r test",
    "test:watch": "pnpm -r test:watch",
    "build": "pnpm --filter @testament/shared build && pnpm --filter @testament/server build"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  }
}
